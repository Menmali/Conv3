{
  "meta": {
    "domain": "diabetes",
    "full_name": "Diabetes Mellitus (Type 2)",
    "icd_codes": ["5A11", "5A10", "5A13"],
    "guidelines": {
      "diagnosis":           "ADA Standards of Medical Care in Diabetes 2024",
      "bmi_classification":  "WHO Obesity Technical Report 2000",
      "insulin_resistance":  "AHA/NHLBI Metabolic Syndrome Statement 2005",
      "gestational_risk":    "ACOG Practice Bulletin No. 190, 2018",
      "glucose_thresholds":  "ADA Standards of Medical Care in Diabetes 2024",
      "hba1c_thresholds":    "ADA Standards of Medical Care in Diabetes 2024"
    },
    "description": "Diabetes mellitus ontology for data coverage assessment. Attribute bins and subclass rules are sourced from ADA 2024 clinical guidelines, WHO BMI classification, AHA/NHLBI metabolic syndrome criteria, and ACOG gestational diabetes guidelines. Invalid_values reflect biologically impossible zeros in Pima dataset that indicate hidden missing data (Problem 2 from Section 2.3.2)."
  },

  "attributes": [
    {
      "id": "pregnancies",
      "label": "Number of Pregnancies",
      "dataset_column": "Pregnancies",
      "aliases": ["pregnancies", "num_pregnancies", "pregnancy_count"],
      "standard": "LOINC",
      "code": "11449-6",
      "type": "continuous",
      "unit": "count",
      "required": false,
      "missing_threshold": 0.10,
      "invalid_values": [],
      "guideline_note": "ACOG Practice Bulletin 190: ≥3 pregnancies increases gestational diabetes risk",
      "coverage_bins": [
        {"label": "nulliparous",    "min": 0, "max": 0,  "note": "No prior pregnancies"},
        {"label": "low_parity",     "min": 1, "max": 2,  "note": "1–2 pregnancies"},
        {"label": "high_parity",    "min": 3, "max": 99, "note": "≥3 pregnancies — ACOG gestational risk threshold"}
      ]
    },
    {
      "id": "glucose",
      "label": "2-Hour OGTT Plasma Glucose",
      "dataset_column": "Glucose",
      "aliases": ["glucose", "plasma_glucose", "blood_glucose", "ogtt"],
      "standard": "LOINC",
      "code": "20436-2",
      "type": "continuous",
      "unit": "mg/dL",
      "required": true,
      "missing_threshold": 0.05,
      "invalid_values": [
        {"value": 0, "note": "Biologically impossible; indicates missing data in Pima dataset (Problem 2)"}
      ],
      "guideline_note": "ADA 2024: FPG <100 normal, 100–125 pre-diabetes (IFG), ≥126 diabetes",
      "coverage_bins": [
        {"label": "normal",       "min": 1,   "max": 99,  "note": "<100 mg/dL — Normal fasting glucose (ADA 2024)"},
        {"label": "pre_diabetes", "min": 100, "max": 125, "note": "100–125 mg/dL — Impaired fasting glucose (ADA 2024)"},
        {"label": "diabetic",     "min": 126, "max": 999, "note": "≥126 mg/dL — Diabetes diagnostic threshold (ADA 2024)"}
      ]
    },
    {
      "id": "blood_pressure",
      "label": "Diastolic Blood Pressure",
      "dataset_column": "BloodPressure",
      "aliases": ["bloodpressure", "blood_pressure", "bp", "diastolic_bp"],
      "standard": "LOINC",
      "code": "8462-4",
      "type": "continuous",
      "unit": "mmHg",
      "required": false,
      "missing_threshold": 0.10,
      "invalid_values": [
        {"value": 0, "note": "Biologically impossible; indicates missing data in Pima dataset (Problem 2)"}
      ],
      "guideline_note": "AHA/NHLBI 2005: diastolic ≥85 mmHg is a metabolic syndrome criterion",
      "coverage_bins": [
        {"label": "normal",    "min": 1,  "max": 84,  "note": "<85 mmHg — Normal diastolic"},
        {"label": "elevated",  "min": 85, "max": 89,  "note": "85–89 mmHg — AHA/NHLBI metabolic syndrome criterion"},
        {"label": "high",      "min": 90, "max": 999, "note": "≥90 mmHg — Hypertension"}
      ]
    },
    {
      "id": "skin_thickness",
      "label": "Triceps Skinfold Thickness",
      "dataset_column": "SkinThickness",
      "aliases": ["skinthickness", "skin_thickness", "triceps_skinfold"],
      "standard": "LOINC",
      "code": "41982-0",
      "type": "continuous",
      "unit": "mm",
      "required": false,
      "missing_threshold": 0.10,
      "invalid_values": [
        {"value": 0, "note": "Biologically impossible; indicates missing data in Pima dataset (Problem 2, ~30% zeros)"}
      ],
      "guideline_note": "Used as indirect body fat measure; values >20mm suggest excess adiposity",
      "coverage_bins": [
        {"label": "low",      "min": 1,  "max": 20,  "note": "≤20 mm — Normal range"},
        {"label": "elevated", "min": 21, "max": 99,  "note": ">20 mm — Elevated adiposity indicator"}
      ]
    },
    {
      "id": "insulin",
      "label": "2-Hour Serum Insulin",
      "dataset_column": "Insulin",
      "aliases": ["insulin", "serum_insulin", "2h_insulin"],
      "standard": "LOINC",
      "code": "20448-7",
      "type": "continuous",
      "unit": "uU/mL",
      "required": false,
      "missing_threshold": 0.10,
      "invalid_values": [
        {"value": 0, "note": "Biologically impossible; indicates missing data in Pima dataset (Problem 2, ~49% zeros)"}
      ],
      "guideline_note": "AHA/NHLBI 2005: fasting insulin >200 uU/mL indicates severe insulin resistance",
      "coverage_bins": [
        {"label": "normal",            "min": 1,   "max": 100, "note": "≤100 uU/mL — Normal insulin sensitivity"},
        {"label": "insulin_resistant",  "min": 101, "max": 200, "note": "101–200 uU/mL — Moderate resistance"},
        {"label": "severely_resistant", "min": 201, "max": 9999,"note": ">200 uU/mL — Severe insulin resistance (AHA/NHLBI criterion)"}
      ]
    },
    {
      "id": "bmi",
      "label": "Body Mass Index",
      "dataset_column": "BMI",
      "aliases": ["bmi", "body_mass_index"],
      "standard": "LOINC",
      "code": "39156-5",
      "type": "continuous",
      "unit": "kg/m2",
      "required": true,
      "missing_threshold": 0.05,
      "invalid_values": [
        {"value": 0, "note": "Biologically impossible; indicates missing data in Pima dataset (Problem 2)"}
      ],
      "guideline_note": "WHO 2000: <25 normal, 25–29.9 overweight, ≥30 obese, ≥35 severely obese",
      "coverage_bins": [
        {"label": "normal",          "min": 1.0,  "max": 24.9, "note": "<25 — Normal weight (WHO 2000)"},
        {"label": "overweight",      "min": 25.0, "max": 29.9, "note": "25–29.9 — Overweight (WHO 2000)"},
        {"label": "obese",           "min": 30.0, "max": 34.9, "note": "30–34.9 — Obese Class I (WHO 2000)"},
        {"label": "severely_obese",  "min": 35.0, "max": 99.9, "note": "≥35 — Obese Class II/III (WHO 2000)"}
      ]
    },
    {
      "id": "diabetes_pedigree",
      "label": "Diabetes Pedigree Function",
      "dataset_column": "DiabetesPedigreeFunction",
      "aliases": ["diabetespedigreefunction", "pedigree", "family_history_score"],
      "standard": "SNOMED CT",
      "code": "160303001",
      "type": "continuous",
      "unit": "score",
      "required": false,
      "missing_threshold": 0.10,
      "invalid_values": [],
      "guideline_note": "ADA 2024: family history is an independent T2DM risk factor; score >0.5 indicates elevated hereditary risk",
      "coverage_bins": [
        {"label": "low_hereditary_risk",      "min": 0.0, "max": 0.499, "note": "≤0.5 — Low family history risk"},
        {"label": "elevated_hereditary_risk", "min": 0.5, "max": 9.999, "note": ">0.5 — Elevated hereditary risk (ADA 2024)"}
      ]
    },
    {
      "id": "age",
      "label": "Patient Age",
      "dataset_column": "Age",
      "aliases": ["age", "patient_age", "AGE"],
      "standard": "LOINC",
      "code": "21612-7",
      "type": "continuous",
      "unit": "years",
      "required": true,
      "missing_threshold": 0.05,
      "invalid_values": [
        {"value": 0, "note": "Age 0 not possible in this dataset (minimum age 21)"}
      ],
      "guideline_note": "ADA 2024: screening recommended from age 35; age ≥45 is an independent T2DM risk factor",
      "coverage_bins": [
        {"label": "young_adult",  "min": 21, "max": 34, "note": "21–34 years — Below ADA screening threshold"},
        {"label": "middle_aged",  "min": 35, "max": 44, "note": "35–44 years — ADA screening begins at 35"},
        {"label": "high_risk_age","min": 45, "max": 59, "note": "45–59 years — Independent T2DM risk factor (ADA 2024)"},
        {"label": "senior",       "min": 60, "max": 120,"note": "≥60 years — Highest age-related risk"}
      ]
    },
    {
      "id": "hba1c",
      "label": "Hemoglobin A1c",
      "dataset_column": null,
      "aliases": ["HbA1c", "A1c", "glycated_hemoglobin", "hba1c"],
      "standard": "LOINC",
      "code": "4548-4",
      "type": "continuous",
      "unit": "%",
      "required": false,
      "missing_threshold": 0.30,
      "invalid_values": [],
      "guideline_note": "ADA 2024: HbA1c ≥6.5% diagnostic for diabetes; 5.7–6.4% pre-diabetes",
      "coverage_bins": [
        {"label": "normal",       "min": 0.0, "max": 5.6, "note": "<5.7% — Normal"},
        {"label": "pre_diabetes", "min": 5.7, "max": 6.4, "note": "5.7–6.4% — Pre-diabetes (ADA 2024)"},
        {"label": "diabetic",     "min": 6.5, "max": 20.0,"note": "≥6.5% — Diabetes diagnostic (ADA 2024)"}
      ]
    },
    {
      "id": "outcome",
      "label": "Diabetes Diagnosis",
      "dataset_column": "Outcome",
      "aliases": ["outcome", "target", "label", "diabetes"],
      "standard": "SNOMED CT",
      "code": "73211009",
      "type": "categorical",
      "required": true,
      "missing_threshold": 0.0,
      "is_target": true,
      "values": [
        {"code": 0, "label": "no_diabetes",  "note": "No diabetes diagnosis"},
        {"code": 1, "label": "diabetes",     "note": "Diabetes diagnosis confirmed"}
      ]
    }
  ],

  "subclasses": [
    {
      "id": "EstablishedT2DM",
      "label": "Established Type 2 Diabetes",
      "short_label": "T2DM",
      "priority": "critical",
      "guideline": "ADA Standards of Medical Care in Diabetes 2024",
      "clinical_note": "Confirmed T2DM: fasting glucose ≥126 mg/dL with positive outcome. Typical presentation includes age ≥45 and BMI ≥30 but these are not required for diagnosis.",
      "key_attributes": ["glucose", "outcome"],
      "min_required_samples": 20,
      "rule": {
        "logic": "AND",
        "conditions": [
          {"attribute": "glucose", "op": ">=", "value": 126},
          {"attribute": "outcome", "op": "==", "value": 1}
        ]
      }
    },
    {
      "id": "PreDiabetesIFG",
      "label": "Pre-Diabetes (Impaired Fasting Glucose)",
      "short_label": "Pre-Diabetes",
      "priority": "high",
      "guideline": "ADA Standards of Medical Care in Diabetes 2024",
      "clinical_note": "Impaired fasting glucose (100–125 mg/dL). High-risk for progression to T2DM.",
      "key_attributes": ["glucose"],
      "min_required_samples": 20,
      "rule": {
        "logic": "AND",
        "conditions": [
          {"attribute": "glucose", "op": ">=", "value": 100},
          {"attribute": "glucose", "op": "<",  "value": 126}
        ]
      }
    },
    {
      "id": "ObeseWithInsulinResistance",
      "label": "Obese with Insulin Resistance",
      "short_label": "Obese+InsulinResist",
      "priority": "high",
      "guideline": "AHA/NHLBI Metabolic Syndrome Statement 2005",
      "clinical_note": "Metabolic syndrome phenotype: severe obesity (BMI ≥35) with severe insulin resistance (insulin >200 uU/mL) and elevated diastolic BP (≥85 mmHg).",
      "key_attributes": ["bmi", "insulin", "blood_pressure"],
      "min_required_samples": 20,
      "rule": {
        "logic": "AND",
        "conditions": [
          {"attribute": "bmi",            "op": ">=", "value": 35},
          {"attribute": "insulin",        "op": ">",  "value": 200},
          {"attribute": "blood_pressure", "op": ">=", "value": 85}
        ]
      }
    },
    {
      "id": "HighParityGestationalRisk",
      "label": "High-Parity Gestational Diabetes Risk",
      "short_label": "Gestational Risk",
      "priority": "medium",
      "guideline": "ACOG Practice Bulletin No. 190, 2018",
      "clinical_note": "Women with ≥3 pregnancies, elevated glucose (≥110 mg/dL), and age ≥30 — ACOG gestational diabetes risk profile.",
      "key_attributes": ["pregnancies", "glucose", "age"],
      "min_required_samples": 20,
      "rule": {
        "logic": "AND",
        "conditions": [
          {"attribute": "pregnancies", "op": ">=", "value": 3},
          {"attribute": "glucose",     "op": ">=", "value": 110},
          {"attribute": "age",         "op": ">=", "value": 30}
        ]
      }
    },
    {
      "id": "MetabolicSyndrome",
      "label": "Metabolic Syndrome (AHA/NHLBI)",
      "short_label": "MetabolicSyndrome",
      "priority": "high",
      "guideline": "AHA/NHLBI Metabolic Syndrome Statement 2005",
      "clinical_note": "Meeting 3+ criteria: elevated glucose (≥100 mg/dL), elevated BP (≥85 mmHg diastolic), elevated triglycerides/HDL, obesity, insulin resistance. Here using glucose+BP+insulin.",
      "key_attributes": ["glucose", "blood_pressure", "insulin"],
      "min_required_samples": 20,
      "rule": {
        "logic": "AND",
        "conditions": [
          {"attribute": "glucose",        "op": ">=", "value": 100},
          {"attribute": "blood_pressure", "op": ">=", "value": 85},
          {"attribute": "insulin",        "op": ">",  "value": 100}
        ]
      }
    },
    {
      "id": "HealthyMetabolicControl",
      "label": "Healthy Metabolic Control",
      "short_label": "Healthy",
      "priority": "medium",
      "guideline": "ADA Standards of Medical Care in Diabetes 2024",
      "clinical_note": "Normal glucose (<100 mg/dL), normal BMI (<25), negative outcome — reference healthy population.",
      "key_attributes": ["glucose", "bmi", "outcome"],
      "min_required_samples": 20,
      "rule": {
        "logic": "AND",
        "conditions": [
          {"attribute": "glucose", "op": "<",  "value": 100},
          {"attribute": "bmi",     "op": "<",  "value": 25},
          {"attribute": "outcome", "op": "==", "value": 0}
        ]
      }
    }
  ],

  "semantic_progression": [
    {
      "stage": 1,
      "attributes": ["age"],
      "description": "Age group coverage — 4 expected bins"
    },
    {
      "stage": 2,
      "attributes": ["age", "glucose"],
      "description": "Age × glucose category — 12 expected combinations"
    },
    {
      "stage": 3,
      "attributes": ["age", "glucose", "bmi"],
      "description": "Age × glucose × BMI classification — 48 expected combinations"
    },
    {
      "stage": 4,
      "attributes": ["age", "glucose", "bmi", "insulin"],
      "description": "Adding insulin resistance status — 144 expected combinations"
    },
    {
      "stage": 5,
      "attributes": ["age", "glucose", "bmi", "insulin", "blood_pressure"],
      "description": "Adding BP (metabolic syndrome component) — 432 expected combinations"
    },
    {
      "stage": 6,
      "attributes": ["age", "glucose", "bmi", "insulin", "blood_pressure", "outcome"],
      "description": "Adding diabetes diagnosis outcome — 864 expected combinations"
    }
  ],

  "thresholds": {
    "sufficient":  0.75,
    "borderline":  0.50,
    "min_samples_per_subclass": 20,
    "_threshold_rationale": "Consistent with cardiovascular domain thresholds. 75% sufficient threshold and 50% borderline threshold follow the same clinical data quality benchmarks applied across all OntoCov domains.",
    "_epv_rationale": "EPV ≥20 per Ogundimu et al. (J Clin Epidemiol 2016) for coefficient stability in clinical prediction models."
  }
}