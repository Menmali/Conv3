    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Stable Angina</rdfs:label>
    <rdfs:comment>Typical angina (cp=1), no exercise-induced symptoms, minimal ST changes (≤1mm), normal perfusion, no vessel obstruction</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2021 AHA/ACC Chest Pain Guideline + 2023 AHA/ACC CCD Guideline</ex:guideline>
