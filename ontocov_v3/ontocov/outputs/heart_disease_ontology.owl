<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ex="http://example.org/heartdisease#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/heartdisease#STDepressionRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>ST-Depression Risk (Flat Slope)</rdfs:label>
    <rdfs:comment>Flat ST slope (slope=2), moderate ST depression (≥2mm), sub-maximal HR response (&lt;140 bpm)</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2023 AHA/ACC CCD Guideline — ST-segment slope analysis</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Diagnosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Diagnosis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#SilentIschaemia">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Silent Ischaemia (Asymptomatic CAD)</rdfs:label>
    <rdfs:comment>Asymptomatic patient (cp=4), no exercise-induced angina, but confirmed CAD diagnosis — the highest-risk missed population</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">critical</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACC/AHA Silent Myocardial Ischaemia Definition</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">29</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#thalach">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Maximum Heart Rate Achieved</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8867-4</ex:loincCode>
    <rdfs:comment>2023 AHA/ACC CCD — HR thresholds define ischaemia severity</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasAgeGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#AgeGroup"/>
    <rdfs:label>hasAgeGroup</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#age">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Patient Age</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">21612-7</ex:loincCode>
    <rdfs:comment>ACC/AHA risk stratification begins at age 45 for men</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#thal_normal">
    <rdf:type rdf:resource="http://example.org/heartdisease#ThaliumStressTestResult"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>normal</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3</ex:code>
    <rdfs:comment>Normal blood flow</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#ThaliumStressTestResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#MedicalTest"/>
    <rdfs:label>Thalium Stress Test Result</rdfs:label>
    <rdfs:comment>Standard: SNOMED CT | Code: 71651007</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">thal</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#ca_two_vessels">
    <rdf:type rdf:resource="http://example.org/heartdisease#NumberOfMajorVesselsWithBlockageFluoroscopy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>two_vessels</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ex:code>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#cp_typical_angina">
    <rdf:type rdf:resource="http://example.org/heartdisease#ChestPainType"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>typical_angina</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1</ex:code>
    <rdfs:comment>Classic effort-related chest pain</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#cp_non_anginal_pain">
    <rdf:type rdf:resource="http://example.org/heartdisease#ChestPainType"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>non_anginal_pain</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3</ex:code>
    <rdfs:comment>Non-ischaemic chest pain</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#trestbps_stage2_hypertension">
    <rdf:type rdf:resource="http://example.org/heartdisease#RestingBloodPressureSystolic"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>stage2_hypertension</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">140.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">999.0</ex:rangeMax>
    <rdfs:comment>≥ 140 mmHg — Stage 2 HTN</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#thalach_low">
    <rdf:type rdf:resource="http://example.org/heartdisease#MaximumHeartRateAchieved"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>low</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">119.0</ex:rangeMax>
    <rdfs:comment>100–119 bpm — SevereIschaemia threshold</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#thalach_normal">
    <rdf:type rdf:resource="http://example.org/heartdisease#MaximumHeartRateAchieved"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>normal</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">140.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">999.0</ex:rangeMax>
    <rdfs:comment>≥ 140 bpm — normal exercise response</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#PatientAge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#AgeGroup"/>
    <rdfs:label>Patient Age</rdfs:label>
    <rdfs:comment>Standard: LOINC | Code: 21612-7 | Unit: years</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">age</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#slope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>Slope of Peak Exercise ST Segment</rdfs:label>
    <ex:snomedCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">164930006</ex:snomedCode>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#BiologicalSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#RiskFactor"/>
    <rdfs:label>Biological Sex</rdfs:label>
    <rdfs:comment>Standard: SNOMED CT | Code: 184100006</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sex</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#thal_reversible_defect">
    <rdf:type rdf:resource="http://example.org/heartdisease#ThaliumStressTestResult"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>reversible_defect</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">7</ex:code>
    <rdfs:comment>Stress-induced deficit — SevereIschaemia indicator</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#slope_downsloping">
    <rdf:type rdf:resource="http://example.org/heartdisease#SlopeOfPeakExerciseStSegment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>downsloping</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3</ex:code>
    <rdfs:comment>Worst prognosis</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#num_very_severe_disease">
    <rdf:type rdf:resource="http://example.org/heartdisease#DiagnosisOfCadTargetVariable"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>very_severe_disease</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4</ex:code>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#slope_flat">
    <rdf:type rdf:resource="http://example.org/heartdisease#SlopeOfPeakExerciseStSegment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>flat</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ex:code>
    <rdfs:comment>Flat slope — STDepressionRisk indicator</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#sex_male">
    <rdf:type rdf:resource="http://example.org/heartdisease#BiologicalSex"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>male</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1</ex:code>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#ExerciseInducedAngina">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#RiskFactor"/>
    <rdfs:label>Exercise-Induced Angina</rdfs:label>
    <rdfs:comment>Standard: SNOMED CT | Code: 194828000</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exang</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#trestbps">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Resting Blood Pressure (Systolic)</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8480-6</ex:loincCode>
    <rdfs:comment>2025 AHA/ACC Hypertension Guideline — four BP categories</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#thalach_moderate">
    <rdf:type rdf:resource="http://example.org/heartdisease#MaximumHeartRateAchieved"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>moderate</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">120.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">139.0</ex:rangeMax>
    <rdfs:comment>120–139 bpm — STDepressionRisk threshold</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#fbs_elevated">
    <rdf:type rdf:resource="http://example.org/heartdisease#FastingBloodSugar120MgDl"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>elevated</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1</ex:code>
    <rdfs:comment>FBS &gt; 120 mg/dL — diabetic indicator</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#ca_zero_vessels">
    <rdf:type rdf:resource="http://example.org/heartdisease#NumberOfMajorVesselsWithBlockageFluoroscopy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>zero_vessels</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0</ex:code>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#DiagnosisOfCadTargetVariable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#Diagnosis"/>
    <rdfs:label>Diagnosis of CAD (Target Variable)</rdfs:label>
    <rdfs:comment>Standard: ICD-11 | Code: BA6Z</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">num</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasCholesterolLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#CholesterolLevel"/>
    <rdfs:label>hasCholesterolLevel</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#fbs_normal">
    <rdf:type rdf:resource="http://example.org/heartdisease#FastingBloodSugar120MgDl"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>normal</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0</ex:code>
    <rdfs:comment>FBS ≤ 120 mg/dL</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#num">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>Diagnosis of CAD (Target Variable)</rdfs:label>
    <ex:snomedCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BA6Z</ex:snomedCode>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#SerumCholesterol">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#CholesterolLevel"/>
    <rdfs:label>Serum Cholesterol</rdfs:label>
    <rdfs:comment>Standard: LOINC | Code: 2093-3 | Unit: mg/dL</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">chol</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#chol_desirable">
    <rdf:type rdf:resource="http://example.org/heartdisease#SerumCholesterol"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>desirable</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">199.0</ex:rangeMax>
    <rdfs:comment>&lt; 200 mg/dL — Desirable</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#num_mild_disease">
    <rdf:type rdf:resource="http://example.org/heartdisease#DiagnosisOfCadTargetVariable"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>mild_disease</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1</ex:code>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#oldpeak_moderate">
    <rdf:type rdf:resource="http://example.org/heartdisease#StDepressionExerciseVsRest"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>moderate</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.01</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">3.0</ex:rangeMax>
    <rdfs:comment>1–3 mm — Moderate depression</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#NonCardiacChestPain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Non-Cardiac Chest Pain</rdfs:label>
    <rdfs:comment>Non-anginal chest pain (cp=3), no exercise-induced symptoms, no ST depression — ruled out as cardiac</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">medium</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2021 AHA/ACC Chest Pain Guideline — noncardiac classification</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">22</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasBloodPressureLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#BloodPressureLevel"/>
    <rdfs:label>hasBloodPressureLevel</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#num_no_disease">
    <rdf:type rdf:resource="http://example.org/heartdisease#DiagnosisOfCadTargetVariable"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>no_disease</rdfs:label>
    <ex:code rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0</ex:code>
    <rdfs:comment>No significant CAD</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#oldpeak">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>ST Depression (Exercise vs Rest)</rdfs:label>
