  <rdf:Description rdf:about="http://example.org/heartdisease#HighRiskCAD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Cardiovascular High-Risk CAD</rdfs:label>
    <rdfs:comment>Male patient ≥45 with Stage 2 hypertension (≥140 mmHg), high total cholesterol (≥240 mg/dL), and elevated fasting blood sugar</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">critical</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2025 AHA/ACC BP Guideline + 2026 ACC/AHA Lipid Guideline</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isCovered>
