    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isStatisticallyAdequate>
