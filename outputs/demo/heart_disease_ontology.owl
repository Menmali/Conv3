<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ex="http://example.org/heartdisease#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/heartdisease#hba1c_diabetic">
    <rdf:type rdf:resource="http://example.org/heartdisease#HemoglobinA1C"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>diabetic</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">6.5</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">20.0</ex:rangeMax>
    <rdfs:comment>≥6.5% — Diabetes diagnostic (ADA 2024)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#skin_thickness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Triceps Skinfold Thickness</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">41982-0</ex:loincCode>
    <rdfs:comment>Used as indirect body fat measure; values &gt;20mm suggest excess adiposity</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#EstablishedT2DM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Established Type 2 Diabetes</rdfs:label>
    <rdfs:comment>Confirmed T2DM: fasting glucose ≥126 mg/dL with positive outcome. Typical presentation includes age ≥45 and BMI ≥30 but these are not required for diagnosis.</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">critical</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADA Standards of Medical Care in Diabetes 2024</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">176</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#DiabetesDiagnosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
    <rdfs:label>Diabetes Diagnosis</rdfs:label>
    <rdfs:comment>Standard: SNOMED CT | Code: 73211009</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Outcome</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasMedicalTest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#MedicalTest"/>
    <rdfs:label>hasMedicalTest</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#ObeseWithInsulinResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Obese with Insulin Resistance</rdfs:label>
    <rdfs:comment>Metabolic syndrome phenotype: severe obesity (BMI ≥35) with severe insulin resistance (insulin &gt;200 uU/mL) and elevated diastolic BP (≥85 mmHg).</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AHA/NHLBI Metabolic Syndrome Statement 2005</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#glucose_pre_diabetes">
    <rdf:type rdf:resource="http://example.org/heartdisease#2HourOgttPlasmaGlucose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>pre_diabetes</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">125.0</ex:rangeMax>
    <rdfs:comment>100–125 mg/dL — Impaired fasting glucose (ADA 2024)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hba1c">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Hemoglobin A1c</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4548-4</ex:loincCode>
    <rdfs:comment>ADA 2024: HbA1c ≥6.5% diagnostic for diabetes; 5.7–6.4% pre-diabetes</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasCholesterolLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#CholesterolLevel"/>
    <rdfs:label>hasCholesterolLevel</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasDiagnosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#Diagnosis"/>
    <rdfs:label>hasDiagnosis</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#outcome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdfs:label>Diabetes Diagnosis</rdfs:label>
    <ex:snomedCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">73211009</ex:snomedCode>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#bmi">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Body Mass Index</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">39156-5</ex:loincCode>
    <rdfs:comment>WHO 2000: &lt;25 normal, 25–29.9 overweight, ≥30 obese, ≥35 severely obese</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#skin_thickness_low">
    <rdf:type rdf:resource="http://example.org/heartdisease#TricepsSkinfoldThickness"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>low</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">20.0</ex:rangeMax>
    <rdfs:comment>≤20 mm — Normal range</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hasBloodPressureLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#BloodPressureLevel"/>
    <rdfs:label>hasBloodPressureLevel</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#hba1c_pre_diabetes">
    <rdf:type rdf:resource="http://example.org/heartdisease#HemoglobinA1C"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>pre_diabetes</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">5.7</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">6.4</ex:rangeMax>
    <rdfs:comment>5.7–6.4% — Pre-diabetes (ADA 2024)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#pregnancies_nulliparous">
    <rdf:type rdf:resource="http://example.org/heartdisease#NumberOfPregnancies"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>nulliparous</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.0</ex:rangeMax>
    <rdfs:comment>No prior pregnancies</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#age">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Patient Age</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">21612-7</ex:loincCode>
    <rdfs:comment>ADA 2024: screening recommended from age 35; age ≥45 is an independent T2DM risk factor</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#bmi_obese">
    <rdf:type rdf:resource="http://example.org/heartdisease#BodyMassIndex"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>obese</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">30.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">34.9</ex:rangeMax>
    <rdfs:comment>30–34.9 — Obese Class I (WHO 2000)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#PreDiabetesIFG">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Pre-Diabetes (Impaired Fasting Glucose)</rdfs:label>
    <rdfs:comment>Impaired fasting glucose (100–125 mg/dL). High-risk for progression to T2DM.</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADA Standards of Medical Care in Diabetes 2024</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">274</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#bmi_severely_obese">
    <rdf:type rdf:resource="http://example.org/heartdisease#BodyMassIndex"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>severely_obese</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">35.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">99.9</ex:rangeMax>
    <rdfs:comment>≥35 — Obese Class II/III (WHO 2000)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#belongsToSubclass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>belongsToSubclass</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Patient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Patient</rdfs:label>
    <rdfs:comment>A patient whose cardiovascular health data is recorded.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#glucose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>2-Hour OGTT Plasma Glucose</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20436-2</ex:loincCode>
    <rdfs:comment>ADA 2024: FPG &lt;100 normal, 100–125 pre-diabetes (IFG), ≥126 diabetes</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#2HourSerumInsulin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
    <rdfs:label>2-Hour Serum Insulin</rdfs:label>
    <rdfs:comment>Standard: LOINC | Code: 20448-7 | Unit: uU/mL</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insulin</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#MetabolicSyndrome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Metabolic Syndrome (AHA/NHLBI)</rdfs:label>
    <rdfs:comment>Meeting 3+ criteria: elevated glucose (≥100 mg/dL), elevated BP (≥85 mmHg diastolic), elevated triglycerides/HDL, obesity, insulin resistance. Here using glucose+BP+insulin.</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AHA/NHLBI Metabolic Syndrome Statement 2005</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">37</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#BodyMassIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
    <rdfs:label>Body Mass Index</rdfs:label>
    <rdfs:comment>Standard: LOINC | Code: 39156-5 | Unit: kg/m2</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BMI</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#HealthyMetabolicControl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>Healthy Metabolic Control</rdfs:label>
    <rdfs:comment>Normal glucose (&lt;100 mg/dL), normal BMI (&lt;25), negative outcome — reference healthy population.</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">medium</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ADA Standards of Medical Care in Diabetes 2024</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">48</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#pregnancies">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label>Number of Pregnancies</rdfs:label>
    <ex:loincCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">11449-6</ex:loincCode>
    <rdfs:comment>ACOG Practice Bulletin 190: ≥3 pregnancies increases gestational diabetes risk</rdfs:comment>
    <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#blood_pressure_normal">
    <rdf:type rdf:resource="http://example.org/heartdisease#DiastolicBloodPressure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>normal</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">84.0</ex:rangeMax>
    <rdfs:comment>&lt;85 mmHg — Normal diastolic</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#HighParityGestationalRisk">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
    <rdfs:label>High-Parity Gestational Diabetes Risk</rdfs:label>
    <rdfs:comment>Women with ≥3 pregnancies, elevated glucose (≥110 mg/dL), and age ≥30 — ACOG gestational diabetes risk profile.</rdfs:comment>
    <ex:priority rdf:datatype="http://www.w3.org/2001/XMLSchema#string">medium</ex:priority>
    <ex:guideline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ACOG Practice Bulletin No. 190, 2018</ex:guideline>
    <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
    <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">211</ex:sampleCount>
    <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
    <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#glucose_normal">
    <rdf:type rdf:resource="http://example.org/heartdisease#2HourOgttPlasmaGlucose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>normal</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">99.0</ex:rangeMax>
    <rdfs:comment>&lt;100 mg/dL — Normal fasting glucose (ADA 2024)</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#DiastolicBloodPressure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
    <rdfs:label>Diastolic Blood Pressure</rdfs:label>
    <rdfs:comment>Standard: LOINC | Code: 8462-4 | Unit: mmHg</rdfs:comment>
    <ex:datasetColumn rdf:datatype="http://www.w3.org/2001/XMLSchema#string">BloodPressure</ex:datasetColumn>
    <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isRequired>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#RiskFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>RiskFactor</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#blood_pressure_high">
    <rdf:type rdf:resource="http://example.org/heartdisease#DiastolicBloodPressure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>high</rdfs:label>
    <ex:rangeMin rdf:datatype="http://www.w3.org/2001/XMLSchema#float">90.0</ex:rangeMin>
    <ex:rangeMax rdf:datatype="http://www.w3.org/2001/XMLSchema#float">999.0</ex:rangeMax>
