    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">23</ex:observedCombinations>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#CoverageStage_6">
    <rdf:type rdf:resource="http://example.org/heartdisease#Stage6_age_sex_cp_trestbps_chol_exang"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Coverage Stage 6: age, sex, cp, trestbps, chol, exang</rdfs:label>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">29.86</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">30300</ex:theoreticalMaxScore>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">576</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">172</ex:observedCombinations>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#SemanticCoverage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>SemanticCoverage</rdfs:label>
    <rdfs:comment>Parent class for all semantic combination coverage stages.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Stage1_age">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
