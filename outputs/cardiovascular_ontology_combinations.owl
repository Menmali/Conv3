  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Stage3_age_sex_cp">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
    <rdfs:label>Stage 3: Age × sex × chest pain type — 24 expected combinations</rdfs:label>
    <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</ex:stageNumber>
    <ex:stageAttributes>age, sex, cp</ex:stageAttributes>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">24</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">23</ex:observedCombinations>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">95.83</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">2400</ex:theoreticalMaxScore>
    <ex:missingCombination>('young_adult', '0', '1')</ex:missingCombination>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#missingCombination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label>missingCombination</rdfs:label>
    <rdfs:comment>a combination tuple absent from the dataset</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#CoverageStage_5">
    <rdf:type rdf:resource="http://example.org/heartdisease#Stage5_age_sex_cp_trestbps_chol"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
