<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:ex="http://example.org/heartdisease#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/heartdisease#stageNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label>stageNumber</rdfs:label>
    <rdfs:comment>stage index 1 through 6</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#CoverageStage_4">
    <rdf:type rdf:resource="http://example.org/heartdisease#Stage4_age_sex_cp_trestbps"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Coverage Stage 4: age, sex, cp, trestbps</rdfs:label>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">78.12</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">9600</ex:theoreticalMaxScore>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">96</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">75</ex:observedCombinations>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Stage4_age_sex_cp_trestbps">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
    <rdfs:label>Stage 4: Adding blood pressure — 96 expected combinations</rdfs:label>
    <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</ex:stageNumber>
    <ex:stageAttributes>age, sex, cp, trestbps</ex:stageAttributes>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">96</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">75</ex:observedCombinations>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">78.12</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">9600</ex:theoreticalMaxScore>
    <ex:missingCombination>('middle_aged', '0', '1', 'elevated')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'normal')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'stage1_hypertension')</ex:missingCombination>
    <ex:missingCombination>('senior', '0', '1', 'elevated')</ex:missingCombination>
    <ex:missingCombination>('senior', '0', '1', 'normal')</ex:missingCombination>
    <ex:missingCombination>('senior', '0', '1', 'stage1_hypertension')</ex:missingCombination>
    <ex:missingCombination>('senior', '0', '2', 'normal')</ex:missingCombination>
    <ex:missingCombination>('senior', '0', '2', 'stage1_hypertension')</ex:missingCombination>
    <ex:missingCombination>('senior', '1', '1', 'elevated')</ex:missingCombination>
    <ex:missingCombination>('senior', '1', '2', 'normal')</ex:missingCombination>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Stage2_age_sex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
    <rdfs:label>Stage 2: Age × sex — 6 expected combinations</rdfs:label>
    <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</ex:stageNumber>
    <ex:stageAttributes>age, sex</ex:stageAttributes>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</ex:observedCombinations>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.0</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">600</ex:theoreticalMaxScore>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#theoreticalMaxScore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label>theoreticalMaxScore</rdfs:label>
    <rdfs:comment>min(n,expected)/expected * 100</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Stage5_age_sex_cp_trestbps_chol">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
    <rdfs:label>Stage 5: Adding cholesterol — 288 expected combinations</rdfs:label>
    <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:stageNumber>
    <ex:stageAttributes>age, sex, cp, trestbps, chol</ex:stageAttributes>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">288</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">141</ex:observedCombinations>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">48.96</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">28800</ex:theoreticalMaxScore>
    <ex:missingCombination>('middle_aged', '0', '1', 'elevated', 'borderline_high')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'elevated', 'desirable')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'elevated', 'high')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'normal', 'borderline_high')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'normal', 'desirable')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'normal', 'high')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'stage1_hypertension', 'borderline_high')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'stage1_hypertension', 'desirable')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'stage1_hypertension', 'high')</ex:missingCombination>
    <ex:missingCombination>('middle_aged', '0', '1', 'stage2_hypertension', 'borderline_high')</ex:missingCombination>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#CoverageStage_3">
