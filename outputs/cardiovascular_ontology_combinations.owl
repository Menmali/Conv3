    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">29.86</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">30300</ex:theoreticalMaxScore>
