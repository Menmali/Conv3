    <rdf:type rdf:resource="http://example.org/heartdisease#Stage1_age"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Coverage Stage 1: age</rdfs:label>
    <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.0</ex:rawCoverageScore>
    <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">300</ex:theoreticalMaxScore>
    <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</ex:expectedCombinations>
    <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</ex:observedCombinations>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/heartdisease#Stage6_age_sex_cp_trestbps_chol_exang">
