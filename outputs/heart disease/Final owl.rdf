        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;, &apos;desirable&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;, &apos;high&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;borderline_high&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;desirable&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;high&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;stage1_hypertension&apos;, &apos;borderline_high&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;stage1_hypertension&apos;, &apos;desirable&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;stage1_hypertension&apos;, &apos;high&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;stage2_hypertension&apos;, &apos;borderline_high&apos;)</ex:missingCombination>
        <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">141</ex:observedCombinations>
        <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">48.96</ex:rawCoverageScore>
        <ex:stageAttributes>age, sex, cp, trestbps, chol</ex:stageAttributes>
        <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ex:stageNumber>
        <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">28800.0</ex:theoreticalMaxScore>
        <rdfs:label>Stage 5: Adding cholesterol — 288 expected combinations</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Stage6_age_sex_cp_trestbps_chol_exang -->

    <owl:Class rdf:about="http://example.org/heartdisease#Stage6_age_sex_cp_trestbps_chol_exang">
