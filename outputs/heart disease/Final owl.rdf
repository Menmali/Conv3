        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;, &apos;desirable&apos;, &apos;1&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;, &apos;high&apos;, &apos;0&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;, &apos;high&apos;, &apos;1&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;borderline_high&apos;, &apos;0&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;borderline_high&apos;, &apos;1&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;desirable&apos;, &apos;0&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;, &apos;desirable&apos;, &apos;1&apos;)</ex:missingCombination>
        <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">172</ex:observedCombinations>
