        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:snomedCode>164931005</ex:snomedCode>
        <rdfs:comment>2023 AHA/ACC CCD — ST depression thresholds: 2 mm for risk, 3 mm for severe</rdfs:comment>
        <rdfs:label>ST Depression (Exercise vs Rest)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#restecg -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#restecg">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:loincCode>11524-6</ex:loincCode>
        <rdfs:label>Resting ECG Results</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#sex -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#sex">
