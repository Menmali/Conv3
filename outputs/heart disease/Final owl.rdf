        <ex:datasetColumn>age</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: LOINC | Code: 21612-7 | Unit: years</rdfs:comment>
        <rdfs:label>Patient Age</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#RestingBloodPressureSystolic -->

    <owl:Class rdf:about="http://example.org/heartdisease#RestingBloodPressureSystolic">
