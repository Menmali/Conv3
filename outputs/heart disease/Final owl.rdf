        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: LOINC | Code: 8480-6 | Unit: mmHg</rdfs:comment>
        <rdfs:label>Resting Blood Pressure (Systolic)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#RestingEcgResults -->

    <owl:Class rdf:about="http://example.org/heartdisease#RestingEcgResults">
