        <ex:datasetColumn>ca</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isRequired>
        <rdfs:comment>Standard: SNOMED CT | Code: 41976001</rdfs:comment>
        <rdfs:label>Number of Major Vessels with Blockage (Fluoroscopy)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Patient -->

    <owl:Class rdf:about="http://example.org/heartdisease#Patient">
        <rdfs:comment>A patient whose cardiovascular health data is recorded.</rdfs:comment>
        <rdfs:label>Patient</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#PatientAge -->

    <owl:Class rdf:about="http://example.org/heartdisease#PatientAge">
