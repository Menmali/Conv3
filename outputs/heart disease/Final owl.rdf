<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/heartdisease#HeartDiseaseOntology_Combinations#"
     xml:base="http://example.org/heartdisease#HeartDiseaseOntology_Combinations"
     xmlns:ex="http://example.org/heartdisease#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/heartdisease#HeartDiseaseOntology_Combinations">
        <ex:datasetRecords rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">303</ex:datasetRecords>
        <ex:mappingVerdict>borderline</ex:mappingVerdict>
        <ex:overallMappingScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.5795</ex:overallMappingScore>
        <ex:semanticCoverage rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.2986</ex:semanticCoverage>
        <ex:subclassCoverage rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.8333</ex:subclassCoverage>
        <rdfs:comment>Auto-generated OWL ontology for Cardiovascular Diseases (CAD). ICD-11 codes: BA6Z, BA40, BA5Z.</rdfs:comment>
        <rdfs:comment>Semantic combination coverage layer. Contains the SemanticCoverage class hierarchy with one OWL class per semantic progression stage, annotated with expected/observed combination counts, raw coverage score, theoretical maximum, and missing combination tuples.</rdfs:comment>
        <rdfs:label>Cardiovascular Diseases (CAD)</rdfs:label>
        <rdfs:label>Cardiovascular Diseases (CAD) — Stage 2b: Combinations</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/heartdisease#code -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#code"/>
    


    <!-- http://example.org/heartdisease#coverageScore -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#coverageScore"/>
    


    <!-- http://example.org/heartdisease#datasetColumn -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#datasetColumn"/>
    


    <!-- http://example.org/heartdisease#datasetRecords -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#datasetRecords"/>
    


    <!-- http://example.org/heartdisease#expectedCombinations -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#expectedCombinations">
        <rdfs:comment>total ontology-defined combinations at this stage</rdfs:comment>
        <rdfs:label>expectedCombinations</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/heartdisease#guideline -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#guideline"/>
    


    <!-- http://example.org/heartdisease#isCovered -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#isCovered"/>
    


    <!-- http://example.org/heartdisease#isRequired -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#isRequired"/>
    


    <!-- http://example.org/heartdisease#isStatisticallyAdequate -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#isStatisticallyAdequate"/>
    


    <!-- http://example.org/heartdisease#loincCode -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#loincCode"/>
    


    <!-- http://example.org/heartdisease#mappingVerdict -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#mappingVerdict"/>
    


    <!-- http://example.org/heartdisease#minRequiredSamples -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#minRequiredSamples"/>
    


    <!-- http://example.org/heartdisease#missingCombination -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#missingCombination">
        <rdfs:comment>a combination tuple absent from the dataset</rdfs:comment>
        <rdfs:label>missingCombination</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/heartdisease#observedCombinations -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#observedCombinations">
        <rdfs:comment>combinations actually present in the dataset</rdfs:comment>
        <rdfs:label>observedCombinations</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/heartdisease#overallMappingScore -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#overallMappingScore"/>
    


    <!-- http://example.org/heartdisease#priority -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#priority"/>
    


    <!-- http://example.org/heartdisease#rangeMax -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#rangeMax"/>
    


    <!-- http://example.org/heartdisease#rangeMin -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#rangeMin"/>
    


    <!-- http://example.org/heartdisease#rawCoverageScore -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#rawCoverageScore">
        <rdfs:comment>observed / expected as a percentage</rdfs:comment>
        <rdfs:label>rawCoverageScore</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/heartdisease#sampleCount -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#sampleCount"/>
    


    <!-- http://example.org/heartdisease#semanticCoverage -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#semanticCoverage"/>
    


    <!-- http://example.org/heartdisease#snomedCode -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#snomedCode"/>
    


    <!-- http://example.org/heartdisease#stageAttributes -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#stageAttributes">
        <rdfs:comment>comma-separated attribute list at this stage</rdfs:comment>
        <rdfs:label>stageAttributes</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/heartdisease#stageNumber -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#stageNumber">
        <rdfs:comment>stage index 1 through 6</rdfs:comment>
        <rdfs:label>stageNumber</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/heartdisease#subclassCoverage -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#subclassCoverage"/>
    


    <!-- http://example.org/heartdisease#theoreticalMaxScore -->

    <owl:AnnotationProperty rdf:about="http://example.org/heartdisease#theoreticalMaxScore">
        <rdfs:comment>min(n,expected)/expected * 100</rdfs:comment>
        <rdfs:label>theoreticalMaxScore</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/heartdisease#belongsToSubclass -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#belongsToSubclass">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <rdfs:label>belongsToSubclass</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasAgeGroup -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasAgeGroup">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#AgeGroup"/>
        <rdfs:label>hasAgeGroup</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasBloodPressureLevel -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasBloodPressureLevel">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#BloodPressureLevel"/>
        <rdfs:label>hasBloodPressureLevel</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasCholesterolLevel -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasCholesterolLevel">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#CholesterolLevel"/>
        <rdfs:label>hasCholesterolLevel</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasClinicalFinding -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasClinicalFinding">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
        <rdfs:label>hasClinicalFinding</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasDiagnosis -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasDiagnosis">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#Diagnosis"/>
        <rdfs:label>hasDiagnosis</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasMedicalTest -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasMedicalTest">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#MedicalTest"/>
        <rdfs:label>hasMedicalTest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/heartdisease#hasRiskFactor -->

    <owl:ObjectProperty rdf:about="http://example.org/heartdisease#hasRiskFactor">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://example.org/heartdisease#RiskFactor"/>
        <rdfs:label>hasRiskFactor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/heartdisease#age -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#age">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:loincCode>21612-7</ex:loincCode>
        <rdfs:comment>ACC/AHA risk stratification begins at age 45 for men</rdfs:comment>
        <rdfs:label>Patient Age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#ca -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#ca">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:snomedCode>41976001</ex:snomedCode>
        <rdfs:label>Number of Major Vessels with Blockage (Fluoroscopy)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#chol -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#chol">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:loincCode>2093-3</ex:loincCode>
        <rdfs:comment>2026 ACC/AHA Lipid Guideline — three cholesterol categories</rdfs:comment>
        <rdfs:label>Serum Cholesterol</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#cp -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#cp">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:snomedCode>29857009</ex:snomedCode>
        <rdfs:comment>2021 AHA/ACC Chest Pain Guideline — four-type classification</rdfs:comment>
        <rdfs:label>Chest Pain Type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#exang -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#exang">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:snomedCode>194828000</ex:snomedCode>
        <rdfs:label>Exercise-Induced Angina</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#fbs -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#fbs">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:loincCode>1558-6</ex:loincCode>
        <rdfs:label>Fasting Blood Sugar &gt; 120 mg/dL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#num -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#num">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:snomedCode>BA6Z</ex:snomedCode>
        <rdfs:label>Diagnosis of CAD (Target Variable)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#oldpeak -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#oldpeak">
