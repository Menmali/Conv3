    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#thalach -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#thalach">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:loincCode>8867-4</ex:loincCode>
        <rdfs:comment>2023 AHA/ACC CCD — HR thresholds define ischaemia severity</rdfs:comment>
        <rdfs:label>Maximum Heart Rate Achieved</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/heartdisease#trestbps -->

    <owl:DatatypeProperty rdf:about="http://example.org/heartdisease#trestbps">
        <rdfs:domain rdf:resource="http://example.org/heartdisease#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <ex:coverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">1.0</ex:coverageScore>
        <ex:loincCode>8480-6</ex:loincCode>
        <rdfs:comment>2017 AHA/ACC Hypertension Guideline — four BP categories</rdfs:comment>
        <rdfs:label>Resting Blood Pressure (Systolic)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/heartdisease#AgeGroup -->

    <owl:Class rdf:about="http://example.org/heartdisease#AgeGroup">
        <rdfs:label>AgeGroup</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#BiologicalSex -->

    <owl:Class rdf:about="http://example.org/heartdisease#BiologicalSex">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#RiskFactor"/>
        <ex:datasetColumn>sex</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: SNOMED CT | Code: 184100006</rdfs:comment>
        <rdfs:label>Biological Sex</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#BloodPressureLevel -->

    <owl:Class rdf:about="http://example.org/heartdisease#BloodPressureLevel">
        <rdfs:label>BloodPressureLevel</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#ChestPainType -->

    <owl:Class rdf:about="http://example.org/heartdisease#ChestPainType">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#RiskFactor"/>
        <ex:datasetColumn>cp</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: SNOMED CT | Code: 29857009</rdfs:comment>
        <rdfs:label>Chest Pain Type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#CholesterolLevel -->

    <owl:Class rdf:about="http://example.org/heartdisease#CholesterolLevel">
        <rdfs:label>CholesterolLevel</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#ClinicalFinding -->

    <owl:Class rdf:about="http://example.org/heartdisease#ClinicalFinding">
        <rdfs:label>ClinicalFinding</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Diagnosis -->

    <owl:Class rdf:about="http://example.org/heartdisease#Diagnosis">
        <rdfs:label>Diagnosis</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#DiagnosisOfCadTargetVariable -->

    <owl:Class rdf:about="http://example.org/heartdisease#DiagnosisOfCadTargetVariable">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#Diagnosis"/>
        <ex:datasetColumn>num</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: ICD-11 | Code: BA6Z</rdfs:comment>
        <rdfs:label>Diagnosis of CAD (Target Variable)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#ExerciseInducedAngina -->

    <owl:Class rdf:about="http://example.org/heartdisease#ExerciseInducedAngina">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#RiskFactor"/>
        <ex:datasetColumn>exang</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: SNOMED CT | Code: 194828000</rdfs:comment>
        <rdfs:label>Exercise-Induced Angina</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#FastingBloodSugar120MgDl -->

    <owl:Class rdf:about="http://example.org/heartdisease#FastingBloodSugar120MgDl">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#RiskFactor"/>
        <ex:datasetColumn>fbs</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: LOINC | Code: 1558-6</rdfs:comment>
        <rdfs:label>Fasting Blood Sugar &gt; 120 mg/dL</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#HighRiskCAD -->

    <owl:Class rdf:about="http://example.org/heartdisease#HighRiskCAD">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <ex:guideline>2017 AHA/ACC BP Guideline + 2018 ACC/AHA Lipid Guideline</ex:guideline>
        <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
        <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isStatisticallyAdequate>
        <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
        <ex:priority>critical</ex:priority>
        <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</ex:sampleCount>
        <rdfs:comment>Male patient ≥45 with Stage 2 hypertension (≥140 mmHg), high total cholesterol (≥240 mg/dL), and elevated fasting blood sugar</rdfs:comment>
        <rdfs:label>Cardiovascular High-Risk CAD</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#MaximumHeartRateAchieved -->

    <owl:Class rdf:about="http://example.org/heartdisease#MaximumHeartRateAchieved">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
        <ex:datasetColumn>thalach</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: LOINC | Code: 8867-4 | Unit: bpm</rdfs:comment>
        <rdfs:label>Maximum Heart Rate Achieved</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#MedicalTest -->

    <owl:Class rdf:about="http://example.org/heartdisease#MedicalTest">
        <rdfs:label>MedicalTest</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#NonCardiacChestPain -->

    <owl:Class rdf:about="http://example.org/heartdisease#NonCardiacChestPain">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <ex:guideline>2021 AHA/ACC Chest Pain Guideline — noncardiac classification</ex:guideline>
        <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
        <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
        <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
        <ex:priority>medium</ex:priority>
        <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</ex:sampleCount>
        <rdfs:comment>Non-anginal chest pain (cp=3), no exercise-induced symptoms, no ST depression — ruled out as cardiac</rdfs:comment>
        <rdfs:label>Non-Cardiac Chest Pain</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#NumberOfMajorVesselsWithBlockageFluoroscopy -->

    <owl:Class rdf:about="http://example.org/heartdisease#NumberOfMajorVesselsWithBlockageFluoroscopy">
