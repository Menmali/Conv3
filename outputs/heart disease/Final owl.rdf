        <rdfs:comment>Standard: LOINC | Code: 11524-6</rdfs:comment>
        <rdfs:label>Resting ECG Results</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#RiskFactor -->

    <owl:Class rdf:about="http://example.org/heartdisease#RiskFactor">
        <rdfs:label>RiskFactor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#STDepressionRisk -->

    <owl:Class rdf:about="http://example.org/heartdisease#STDepressionRisk">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <ex:guideline>2023 AHA/ACC CCD Guideline — ST-segment slope analysis</ex:guideline>
        <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
        <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
        <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
        <ex:priority>high</ex:priority>
        <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">25</ex:sampleCount>
        <rdfs:comment>Flat ST slope (slope=2), moderate ST depression (≥2mm), sub-maximal HR response (&lt;140 bpm)</rdfs:comment>
        <rdfs:label>ST-Depression Risk (Flat Slope)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#SemanticCoverage -->

    <owl:Class rdf:about="http://example.org/heartdisease#SemanticCoverage">
        <rdfs:comment>Parent class for all semantic combination coverage stages.</rdfs:comment>
        <rdfs:label>SemanticCoverage</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#SerumCholesterol -->

    <owl:Class rdf:about="http://example.org/heartdisease#SerumCholesterol">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#CholesterolLevel"/>
        <ex:datasetColumn>chol</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: LOINC | Code: 2093-3 | Unit: mg/dL</rdfs:comment>
        <rdfs:label>Serum Cholesterol</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#SevereIschaemia -->

    <owl:Class rdf:about="http://example.org/heartdisease#SevereIschaemia">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <ex:guideline>2023 AHA/ACC CCD Guideline — multi-vessel disease classification</ex:guideline>
        <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isCovered>
        <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isStatisticallyAdequate>
        <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
        <ex:priority>critical</ex:priority>
        <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</ex:sampleCount>
        <rdfs:comment>Severe ST depression (&gt;3mm), very low max HR (&lt;120 bpm), abnormal perfusion (thal≠3), multi-vessel disease (ca≥2)</rdfs:comment>
        <rdfs:label>Severe Ischaemia</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#SilentIschaemia -->

    <owl:Class rdf:about="http://example.org/heartdisease#SilentIschaemia">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <ex:guideline>ACC/AHA Silent Myocardial Ischaemia Definition</ex:guideline>
        <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
        <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isStatisticallyAdequate>
        <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
        <ex:priority>critical</ex:priority>
        <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">35</ex:sampleCount>
        <rdfs:comment>Asymptomatic patient (cp=4), no exercise-induced angina, but confirmed CAD diagnosis — the highest-risk missed population</rdfs:comment>
        <rdfs:label>Silent Ischaemia (Asymptomatic CAD)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#SlopeOfPeakExerciseStSegment -->

    <owl:Class rdf:about="http://example.org/heartdisease#SlopeOfPeakExerciseStSegment">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#MedicalTest"/>
        <ex:datasetColumn>slope</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isRequired>
        <rdfs:comment>Standard: SNOMED CT | Code: 164930006</rdfs:comment>
        <rdfs:label>Slope of Peak Exercise ST Segment</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#StDepressionExerciseVsRest -->

    <owl:Class rdf:about="http://example.org/heartdisease#StDepressionExerciseVsRest">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#ClinicalFinding"/>
        <ex:datasetColumn>oldpeak</ex:datasetColumn>
        <ex:isRequired rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isRequired>
        <rdfs:comment>Standard: SNOMED CT | Code: 164931005 | Unit: mm</rdfs:comment>
        <rdfs:label>ST Depression (Exercise vs Rest)</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#StableAngina -->

    <owl:Class rdf:about="http://example.org/heartdisease#StableAngina">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SubclassProfile"/>
        <ex:guideline>2021 AHA/ACC Chest Pain Guideline + 2023 AHA/ACC CCD Guideline</ex:guideline>
        <ex:isCovered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ex:isCovered>
        <ex:isStatisticallyAdequate rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ex:isStatisticallyAdequate>
        <ex:minRequiredSamples rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</ex:minRequiredSamples>
        <ex:priority>high</ex:priority>
        <ex:sampleCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</ex:sampleCount>
        <rdfs:comment>Typical angina (cp=1), no exercise-induced symptoms, minimal ST changes (≤1mm), normal perfusion, no vessel obstruction</rdfs:comment>
        <rdfs:label>Stable Angina</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Stage1_age -->

    <owl:Class rdf:about="http://example.org/heartdisease#Stage1_age">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
        <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</ex:expectedCombinations>
        <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</ex:observedCombinations>
        <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.0</ex:rawCoverageScore>
        <ex:stageAttributes>age</ex:stageAttributes>
        <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</ex:stageNumber>
        <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">300.0</ex:theoreticalMaxScore>
        <rdfs:label>Stage 1: Age group coverage — 3 expected bins</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Stage2_age_sex -->

    <owl:Class rdf:about="http://example.org/heartdisease#Stage2_age_sex">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
        <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</ex:expectedCombinations>
        <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</ex:observedCombinations>
        <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">100.0</ex:rawCoverageScore>
        <ex:stageAttributes>age, sex</ex:stageAttributes>
        <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</ex:stageNumber>
        <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">600.0</ex:theoreticalMaxScore>
        <rdfs:label>Stage 2: Age × sex — 6 expected combinations</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Stage3_age_sex_cp -->

    <owl:Class rdf:about="http://example.org/heartdisease#Stage3_age_sex_cp">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
        <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">24</ex:expectedCombinations>
        <ex:missingCombination>(&apos;young_adult&apos;, &apos;0&apos;, &apos;1&apos;)</ex:missingCombination>
        <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">23</ex:observedCombinations>
        <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">95.83</ex:rawCoverageScore>
        <ex:stageAttributes>age, sex, cp</ex:stageAttributes>
        <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</ex:stageNumber>
        <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">2400.0</ex:theoreticalMaxScore>
        <rdfs:label>Stage 3: Age × sex × chest pain type — 24 expected combinations</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Stage4_age_sex_cp_trestbps -->

    <owl:Class rdf:about="http://example.org/heartdisease#Stage4_age_sex_cp_trestbps">
        <rdfs:subClassOf rdf:resource="http://example.org/heartdisease#SemanticCoverage"/>
        <ex:expectedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">96</ex:expectedCombinations>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;middle_aged&apos;, &apos;0&apos;, &apos;1&apos;, &apos;stage1_hypertension&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;0&apos;, &apos;1&apos;, &apos;elevated&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;0&apos;, &apos;1&apos;, &apos;normal&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;0&apos;, &apos;1&apos;, &apos;stage1_hypertension&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;0&apos;, &apos;2&apos;, &apos;normal&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;0&apos;, &apos;2&apos;, &apos;stage1_hypertension&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;1&apos;, &apos;1&apos;, &apos;elevated&apos;)</ex:missingCombination>
        <ex:missingCombination>(&apos;senior&apos;, &apos;1&apos;, &apos;2&apos;, &apos;normal&apos;)</ex:missingCombination>
        <ex:observedCombinations rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">75</ex:observedCombinations>
        <ex:rawCoverageScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">78.12</ex:rawCoverageScore>
        <ex:stageAttributes>age, sex, cp, trestbps</ex:stageAttributes>
        <ex:stageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</ex:stageNumber>
        <ex:theoreticalMaxScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">9600.0</ex:theoreticalMaxScore>
        <rdfs:label>Stage 4: Adding blood pressure — 96 expected combinations</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/heartdisease#Stage5_age_sex_cp_trestbps_chol -->

    <owl:Class rdf:about="http://example.org/heartdisease#Stage5_age_sex_cp_trestbps_chol">
